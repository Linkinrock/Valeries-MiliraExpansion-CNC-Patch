<?xml version="1.0" encoding="utf-8" ?>

<Patch>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/RecipeDef[
      defName="MEXY_Synthetizing_GravilatticeAlloy" or 
      defName="MEXY_Synthetizing_GravilatticeSilk" or 
      defName="MEXY_Synthetizing_PsycholuxCrystal" or 
      defName="MEXY_Synthetizing_OverloadCrystal" or 
      defName="MEXY_Synthetizing_OracleCrystal" or 
      defName="MEXY_Synthetizing_MiracleCrystal" or
	  defName="MEXY_SanctisSigil" or
	  defName="MEXY_Luxplume_Array_Prototype"
    ]/recipeUsers</xpath>
    <value>
      <li>Milira_CNCMachiningCenter</li>
    </value>
  </Operation>
  
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[
	  defName="MEXY_Aetherim_Judicator" or
	  defName="MEXY_Annihilation_Storm" or
	  defName="MEXY_SanctisSigil"
	  ]/recipeMaker/recipeUsers</xpath>
    <value>
      <li>Milira_CNCMachiningCenter</li>
    </value>
  </Operation>
</Patch>